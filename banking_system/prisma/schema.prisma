generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  ADMIN       // Master system control
  MANAGER     // Branch oversight
  ACCOUNTANT  // Onboarding and auditing
  CASHIER     // Transaction handling
  CUSTOMER    // Standard user banking
}

enum AccountType {
  SAVINGS
  CURRENT
  FIXED_DEPOSIT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
}

// --- MODELS ---

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  email           String    @unique
  fullName        String    // Required field for core identification
  password        String    // Required field
  role            Role      @default(CUSTOMER) // Required field
  createdAt       DateTime  @default(now())

  // --- Optional Client Details (For Customer Form) ---
  firstName       String?
  lastName        String?
  phone           String?
  aadharNo        String?   @unique // Still unique to prevent duplicate KYC
  age             Int?
  gender          String?
  
  // --- Optional Location Details ---
  address         String?
  city            String?
  landmark        String?
  pincode         String?
  state           String?
  
  // 📸 Stores the Cloudinary Secure URL
  clientSign      String?   
  
  // --- Optional Nominee Information ---
  nomineeName     String?
  nomineePhone    String?
  nomineeAddress  String?
  nomineeEmail    String?
  nomineeSign     String?   

  accounts        Account[]
}

model Account {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  accountNumber String      @unique
  accountType   AccountType @default(SAVINGS)
  balance       Float       @default(0.0)
  userId        String      @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  transactions  Transaction[]
}

model Transaction {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  amount          Float
  transactionType TransactionType
  description     String?
  createdAt       DateTime        @default(now())
  accountId       String          @db.ObjectId
  account         Account         @relation(fields: [accountId], references: [id])
  processedBy     String?         // Audit field for staff tracking
}

// 🔒 INSTITUTIONAL SECURITY MODEL: OTP
// Tracks temporary digital signatures for Vault Recovery & Enrollment.
model Otp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  code      String
  expiresAt DateTime 
  createdAt DateTime @default(now())
}