generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
// Enums provide a fixed list of choices, preventing typos in the database.
enum Role {
  ADMIN //Full system access
  MANAGER // Full system access
  ACCOUNTANT // Financial auditing and reporting
  CASHIER // Daily transaction handling
  CUSTOMER // Standard user banking
}

enum AccountType {
  SAVINGS
  CURRENT
  FIXED_DEPOSIT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
}

// --- MODELS ---

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  email     String    @unique
  fullName  String
  password  String
  role      Role      @default(CUSTOMER) // Defaults to CUSTOMER for security
  createdAt DateTime  @default(now())
  accounts  Account[]
}

model Account {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  accountNumber String        @unique
  accountType   AccountType   @default(SAVINGS)
  balance       Float         @default(0.0)
  userId        String        @db.ObjectId
  user          User          @relation(fields: [userId], references: [id])
  transactions  Transaction[]
}

model Transaction {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  amount          Float
  transactionType TransactionType
  description     String? // Optional: e.g., "ATM Withdrawal" or "Monthly Salary"
  createdAt       DateTime        @default(now())
  accountId       String          @db.ObjectId
  account         Account         @relation(fields: [accountId], references: [id])

  // Track which staff member handled the transaction (if any)
  processedBy String? // Useful for Cashier/Manager auditing
}
